<IfModule mod_rewrite.c>
    RewriteEngine On
    # Ensure not already in public folder
    RewriteCond %{REQUEST_URI} !^/public/

    # If the file/dir does not exist
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Rewrite to public
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
