<IfModule mod_rewrite.c>
    RewriteEngine On
    # Ensure not already in public folder
    RewriteCond %{REQUEST_URI} !^/workopia/public/

    # If the file does not exist, rewrite to public
    RewriteCond %{REQUEST_FILENAME} !-f

    # Rewrite to public
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
